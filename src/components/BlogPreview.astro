---
interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      tags?: string[];
      heroImage?: string;
    };
  }>;
}

const { posts } = Astro.props;
---

<section class="section" id="blog">
  <div class="container">
    <p class="section-label">Writing</p>
    <h2 class="section-title">From the <span>Blog</span></h2>
    <p class="section-desc">
      Thoughts on web development, AV systems, and building things that work at scale.
    </p>

    <div class="blog-grid">
      {posts.slice(0, 3).map(post => (
        <article class="card blog-card">
          {post.data.heroImage && (
            <div class="bc-img">
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            </div>
          )}
          <div class="bc-body">
            <div class="bc-meta">
              <time
                datetime={post.data.pubDate.toISOString()}
                class="bc-date"
              >
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric',
                })}
              </time>
              {post.data.tags && post.data.tags[0] && (
                <span class="tag">{post.data.tags[0]}</span>
              )}
            </div>
            <h3 class="bc-title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="bc-desc">{post.data.description}</p>
            <a href={`/blog/${post.id}`} class="bc-read">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="blog-all">
      <a href="/blog" class="btn btn-outline">
        All posts
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .bc-img {
    height: 200px;
    overflow: hidden;
    background: var(--bg-card2);
  }
  .bc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .bc-img img { transform: scale(1.04); }

  .bc-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }
  .bc-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .bc-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
  .bc-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .bc-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .bc-title a:hover { color: var(--accent); opacity: 1; }
  .bc-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
    max-width: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bc-read {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.2s;
  }
  .bc-read:hover { gap: 0.6rem; opacity: 1; }

  .blog-all {
    display: flex;
    justify-content: center;
  }
</style>
