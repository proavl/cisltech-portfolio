---

<section class="section" id="projects">
  <div class="container">
    <p class="section-label">What I've built</p>
    <h2 class="section-title">Projects <span>&amp; Work</span></h2>
    <p class="section-desc">
      A mix of company builds, large-scale AV integrations, and open-source work.
    </p>

    <!-- Featured projects -->
    <div class="projects-featured">
      {projects.filter(p => p.featured).map(project => (
        <article class="card project-featured">
          <div class="pf-top">
            <div class="pf-icon" aria-hidden="true">{project.icon}</div>
            <div class="pf-meta">
              <span class="tag tag-category">{project.category}</span>
              <span class="pf-year">{project.year}</span>
            </div>
          </div>
          <h3 class="pf-title">{project.title}</h3>
          <p class="pf-desc">{project.description}</p>
          <div class="pf-tags">
            {project.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          <div class="pf-links">
            {project.link && project.link !== project.github && (
              <a href={project.link} target="_blank" rel="noopener" class="pf-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Live site
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener" class="pf-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Grid of other projects -->
    <div class="projects-grid">
      {projects.filter(p => !p.featured).map(project => (
        <article class="card project-card">
          <div class="pc-top">
            <span class="pc-icon" aria-hidden="true">{project.icon}</span>
            <span class="tag tag-category">{project.category}</span>
          </div>
          <h3 class="pc-title">{project.title}</h3>
          <p class="pc-desc">{project.description}</p>
          <div class="pc-footer">
            <div class="pf-tags">
              {project.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
            </div>
            <span class="pc-year">{project.year}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="projects-more">
      <a
        href="https://github.com/proavl"
        target="_blank"
        rel="noopener"
        class="btn btn-outline"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        More on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .projects-featured {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .project-featured {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pf-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pf-icon {
    font-size: 1.8rem;
    line-height: 1;
  }
  .pf-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .pf-year {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .pf-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }
  .pf-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
    max-width: none;
  }
  .pf-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pf-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .pf-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .pf-link:hover { color: var(--accent); opacity: 1; }

  .tag-category {
    background: rgba(124, 58, 237, 0.15);
    color: #a78bfa;
    border-color: rgba(124, 58, 237, 0.25);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .project-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pc-icon { font-size: 1.4rem; }
  .pc-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  .pc-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
    max-width: none;
  }
  .pc-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .pc-year {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .projects-more {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }
</style>
