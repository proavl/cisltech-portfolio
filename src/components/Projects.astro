    tags: ['Web Development', 'AV Systems', 'WordPress', 'Systems Integration'],
    link: 'https://loud-dxb.com',
    github: null,
    featured: true,
    year: '2015–present',
    category: 'Company',
    icon: '🔊',
  },
  {
    title: 'TERHAL by Dragone — KSA',
    description:
      'Specialist production technology for the TERHAL show in Diryah, Riyadh. Scope included central chandelier systems, props, and full Kabuki system supply, installation, commissioning, and programming.',
    tags: ['Production Technology', 'Kabuki Systems', 'Commissioning', 'Programming'],
    link: null,
