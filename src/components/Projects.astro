    featured: false,
    year: '2022',
    category: 'AV Project',
    icon: '💡',
  },
  {
    title: 'En Fuego — Atlantis The Palm',
    description:
      'Comprehensive lighting and video system design, supply, installation, and full commissioning for En Fuego at Atlantis The Palm, Dubai.',
    tags: ['Lighting Design', 'Video Design', 'Commissioning'],
    link: null,
    github: null,
    featured: false,
    year: '2022',
    category: 'AV Project',
    icon: '🔥',
  },
  {
    title: 'Bla Bla Beach Club — JBR',
    description:
      'End-to-end lighting and video design for Bla Bla Beach Club at JBR The Walk, Dubai — a high-profile venue requiring robust outdoor and indoor integrated systems.',
    tags: ['Lighting Design', 'Outdoor AV', 'JBR', 'Integration'],
    link: null,
    github: null,
    featured: false,
    year: '2021',
    category: 'AV Project',
    icon: '🏖️',
  },
  {
    title: 'CISLTECH — Digital Infrastructure',
    description:
      'CISLTECH is Ian\'s technology organisation focused on systems integration, custom software development, and digital infrastructure for hospitality and entertainment clients.',
    tags: ['Systems Integration', 'Software Development', 'GitHub', 'Open Source'],
    link: 'https://github.com/CISLTECH',
    github: 'https://github.com/CISLTECH',
    featured: true,
    year: '2020–present',
    category: 'Org',
