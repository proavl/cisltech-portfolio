---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))];
---

<BaseLayout
  title="Blog — Ian Lazala"
  description="Thoughts on web development, AV systems integration, and building things that work."
>
  <div class="blog-page">
    <div class="container">
      <header class="blog-page-header">
        <p class="section-label">Writing</p>
        <h1 class="blog-page-title">Blog</h1>
        <p class="blog-page-desc">
          Thoughts on web development, AV systems, open-source, and building products from Dubai.
        </p>
        {allTags.length > 0 && (
          <div class="blog-tags-filter">
            <a href="/blog" class="tag-pill active">All</a>
            {allTags.map(tag => (
              <a href={`/blog/tag/${tag}`} class="tag-pill">{tag}</a>
            ))}
          </div>
        )}
      </header>

      {posts.length === 0 ? (
        <div class="no-posts">
          <p>No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="blog-list">
          {posts.map(post => (
            <article class="card blog-list-item">
              <div class="bli-date-col">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="bli-date"
                >
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric', month: 'short', day: 'numeric',
                  })}
                </time>
              </div>
              <div class="bli-content">
                <h2 class="bli-title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="bli-desc">{post.data.description}</p>
                {post.data.tags && (
                  <div class="bli-tags">
                    {post.data.tags.map(t => <span class="tag">{t}</span>)}
                  </div>
                )}
              </div>
              <div class="bli-arrow">
                <a href={`/blog/${post.id}`} aria-label={`Read ${post.data.title}`}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-page {
    padding: 8rem 0 6rem;
  }
  .blog-page-header {
    margin-bottom: 3rem;
  }
  .blog-page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }
  .blog-page-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 55ch;
    margin-bottom: 1.5rem;
  }
  .blog-tags-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-pill {
    padding: 0.3rem 0.9rem;
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 99px;
    background: var(--bg-card);
    text-decoration: none;
    transition: all 0.2s;
  }
  .tag-pill:hover, .tag-pill.active {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
    opacity: 1;
  }

  .no-posts {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .blog-list-item {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding: 1.75rem;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: 1px solid var(--border);
    border-bottom: none;
    background: transparent;
    transition: background 0.2s;
  }
  .blog-list-item:first-child {
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
  .blog-list-item:last-child {
    border-bottom: 1px solid var(--border);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }
  .blog-list-item:hover {
    background: var(--bg-card);
    transform: none;
    box-shadow: none;
  }
  .bli-date {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    padding-top: 0.2rem;
  }
  .bli-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .bli-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .bli-title a:hover { color: var(--accent); opacity: 1; }
  .bli-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    max-width: 70ch;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
  .bli-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .bli-arrow {
    display: flex;
    align-items: center;
    padding-top: 0.2rem;
  }
  .bli-arrow a {
    display: flex;
    align-items: center;
    color: var(--text-dim);
    transition: color 0.2s, transform 0.2s;
  }
  .blog-list-item:hover .bli-arrow a {
    color: var(--accent);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .blog-list-item {
      grid-template-columns: 1fr auto;
    }
    .bli-date-col { display: none; }
    .bli-date {
      display: block;
      margin-bottom: 0.5rem;
    }
    .bli-content::before {
      content: attr(data-date);
    }
  }
</style>
